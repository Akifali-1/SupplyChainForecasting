# Google OAuth Credentials (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Session secret — generate a strong random string
SESSION_SECRET=your_session_secret_here

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/supplychain?retryWrites=true&w=majority
MONGO_DB=supplychain

# ML Service URL (default for local development)
ML_SERVICE_URL=http://localhost:5001